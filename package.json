{
  "name": "openterface-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "submodules/Openterface_WebUI/packages/*"
  ],
  "scripts": {
    "dev:usb": "npm -w @openterface/usb run dev",
    "dev:webrtc": "npm -w @openterface/webrtc run dev",
    "build": "npm run build:wasm && npm run build:usb && npm run build:webrtc:android && npm run build:combine",
    "build:wasm": "bash wasm-build/build.sh Openterface_Core packages/core/wasm",
    "build:usb": "npm -w @openterface/usb run build",
    "build:webrtc:android": "npm -w @openterface/webrtc run build",
    "build:combine": "rm -rf dist && mkdir -p dist && cp -r packages/usb/dist/* dist/ && mkdir -p dist/webrtc-android && cp -r submodules/Openterface_WebUI/packages/webrtc/dist/webrtc-android/* dist/webrtc-android/",
    "preview:usb": "npm -w @openterface/usb run preview",
    "preview:webrtc": "npm -w @openterface/webrtc run preview",
    "typecheck": "npm run typecheck -ws"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/dom-serial": "^1.0.6",
    "@types/w3c-web-serial": "^1.0.8",
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.10"
  }
}
